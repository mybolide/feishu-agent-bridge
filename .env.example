# Required (minimum)
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional (iFlow timeout tuning)
IFLOW_FIRST_TOKEN_TIMEOUT_MS=180000
IFLOW_RECEIVE_IDLE_TIMEOUT_MS=180000
IFLOW_UNHEALTHY_SESSION_TTL_MS=1800000

# Optional (OpenCode timeout tuning)
OPENCODE_SERVER_URL=http://127.0.0.1:24096
OPENCODE_MESSAGE_POLL_TIMEOUT_MS=600000
OPENCODE_MESSAGE_POLL_INTERVAL_MS=2000
OPENCODE_WAIT_FOREVER_AFTER_PROGRESS=true
OPENCODE_SESSION_LIST_TIMEOUT_MS=45000
OPENCODE_SESSION_LIST_RETRY_ATTEMPTS=3
OPENCODE_SESSION_LIST_RETRY_DELAY_MS=800
OPENCODE_SESSION_MESSAGES_RETRY_ATTEMPTS=3
OPENCODE_SESSION_MESSAGES_RETRY_DELAY_MS=600
OPENCODE_MODEL_LIST_TIMEOUT_MS=30000
OPENCODE_MODEL_LIST_RETRY_ATTEMPTS=3
OPENCODE_MODEL_LIST_RETRY_DELAY_MS=500
OPENCODE_HEALTHCHECK_TIMEOUT_MS=1500
OPENCODE_DISCOVERY_SCAN_LIMIT=40
OPENCODE_DISCOVERY_ROUNDS=3
OPENCODE_DISCOVERY_RETRY_DELAY_MS=400
OPENCODE_DISCOVERY_CACHE_TTL_MS=5000
